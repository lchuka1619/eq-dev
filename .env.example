# Copy this file to .env.local and replace the placeholders.
# Never commit .env.local or real credentials.

# Public browser-safe Supabase configuration
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_PUBLISHABLE_KEY"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_LEGACY_SUPABASE_ANON_KEY"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Personal Practice pilot feature flag. Set false to keep the existing Sprint 6 Today card.
NEXT_PUBLIC_PAST_EVENT_PILOT="true"

# Server-only AI configuration
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Server-only database configuration (migration/tooling only)
POSTGRES_DATABASE="postgres"
POSTGRES_HOST="db.YOUR_PROJECT_REF.supabase.co"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="YOUR_DATABASE_PASSWORD"
POSTGRES_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require"
POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# Privileged Supabase values: server-side only. Never expose with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY="YOUR_SUPABASE_SECRET_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
SUPABASE_JWT_SECRET="YOUR_SUPABASE_JWT_SECRET"
